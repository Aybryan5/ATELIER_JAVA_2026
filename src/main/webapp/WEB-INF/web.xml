<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Mini Gestionnaire de Taches</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>AddTaskServlet</servlet-name>
        <servlet-class>fr.bryan.taskmanager.servlet.AddTaskServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddTaskServlet</servlet-name>
        <url-pattern>/add-task</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteTaskServlet</servlet-name>
        <servlet-class>fr.bryan.taskmanager.servlet.DeleteTaskServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteTaskServlet</servlet-name>
        <url-pattern>/delete-task</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CompleteTaskServlet</servlet-name>
        <servlet-class>fr.bryan.taskmanager.servlet.CompleteTaskServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CompleteTaskServlet</servlet-name>
        <url-pattern>/complete-task</url-pattern>
    </servlet-mapping>
</web-app>
